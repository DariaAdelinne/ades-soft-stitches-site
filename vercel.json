{
  "buildCommand": "python3 scripts/genereaza_catalog.py",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://res.cloudinary.com https://*.cloudinary.com https://firebasestorage.googleapis.com https://storage.googleapis.com; connect-src 'self' https://*.firebaseio.com https://*.firebasedatabase.app https://europe-west1-ades-soft-stitches.cloudfunctions.net https://api.cloudinary.com; form-action 'self'; frame-src 'none'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/continut/index.html"
    },
    {
      "source": "/produse",
      "destination": "/continut/index.html"
    },
    {
      "source": "/produse/:produs",
      "destination": "/continut/index.html"
    },
    {
      "source": "/comanda",
      "destination": "/continut/index.html"
    },
    {
      "source": "/review-uri",
      "destination": "/continut/index.html"
    },
    {
      "source": "/despre",
      "destination": "/continut/index.html"
    },
    {
      "source": "/admin-produse",
      "destination": "/continut/index.html"
    },
    {
      "source": "/admin-review-uri",
      "destination": "/continut/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/continut/:path*"
    }
  ]
}
